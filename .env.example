PORT=3000
NODE_ENV=development

# Public app origins.
APP_BASE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-random-secret

# Optional external Postgres override.
# Leave empty for local embedded Postgres via project npm scripts.
# Required for docker-compose external-postgres deployment.
DATABASE_URL=

# Local/default embedded Postgres runtime.
EMBEDDED_POSTGRES_HOST=127.0.0.1
EMBEDDED_POSTGRES_PORT=54329
EMBEDDED_POSTGRES_DB=teamcal
EMBEDDED_POSTGRES_USER=postgres
EMBEDDED_POSTGRES_PASSWORD=postgres
EMBEDDED_POSTGRES_DATA_DIR=./data/postgres
# Set to true only in environments where creating a postgres user is acceptable.
EMBEDDED_POSTGRES_CREATE_USER=false

GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

TOKEN_ENC_KEY=replace-with-32-byte-base64-or-64-hex

RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_AVAILABILITY_MAX=120
RATE_LIMIT_BOOKING_MAX=30

# Optional integration envs.
BOOKING_WEBHOOK_URL=
BOOKING_TOKEN=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Team Calendar
